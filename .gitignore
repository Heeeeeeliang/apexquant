models/
# data/ is BOTH a runtime cache dir AND a Python source
# package (51 source files import from it). Ignore runtime
# artifacts only; preserve source code.
data/**/*.csv
data/**/*.parquet
data/**/*.feather
data/**/*.pkl
data/**/*.h5
data/**/*.npy
data/cache/
data/raw/
data/processed/
