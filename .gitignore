results/
backtest/cache/
logs/
*.log
*.pkl
*.ckpt
*.pt
*.pth
*.parquet
*.npy
*.h5

# Bundled demo data + checkpoints — explicitly tracked so they survive
# the blanket models/ and data/ ignores above, and the *.pt / *.joblib
# suffix ignores, without turning those rules off globally.
!examples/
!examples/**
!examples/sample_data/
!examples/sample_data/**
!examples/sample_checkpoints/
!examples/sample_checkpoints/**

.streamlit/secrets.toml
